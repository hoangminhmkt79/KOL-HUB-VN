# PostgreSQL từ Neon / Supabase / Railway
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Hash SHA-256 của mật khẩu admin (KHÔNG điền mật khẩu thật vào đây)
# Tạo hash: echo -n "matkhaucuaban" | sha256sum
# Ví dụ hash của "Minhaff79":
ADMIN_HASH=b854c4d5ddf5a543e24e5cc202a78cec9722360a5311906c873d731bbd630436

# KHÔNG cần NEXT_PUBLIC_ADMIN_PASSWORD nữa — đã chuyển sang server-side
